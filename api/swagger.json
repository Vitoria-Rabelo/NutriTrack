{
  "openapi": "3.0.0",
  "info": {
    "title": "NutriTrack API",
    "version": "1.0.0",
    "description": "Documentação interativa das rotas do ecossistema NutriTrack"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "tags": [
    {
      "name": "Pacientes",
      "description": "Gerenciamento de pacientes e planos alimentares"
    },
    {
      "name": "Receitas",
      "description": "Gerenciamento do catálogo de receitas"
    },
    {
      "name": "Agendamentos",
      "description": "Gerenciamento de consultas e agendamentos"
    }
  ],
  "paths": {
    "/api/pacientes": {
      "get": {
        "tags": [
          "Pacientes"
        ],
        "summary": "Lista todos os pacientes cadastrados",
        "description": "Retorna um array com todos os documentos de pacientes vindos do Firestore.",
        "responses": {
          "200": {
            "description": "Lista de pacientes retornada com sucesso."
          }
        }
      },
      "post": {
        "tags": [
          "Pacientes"
        ],
        "summary": "Cria um novo paciente com seu plano alimentar",
        "description": "Envia os dados do paciente para a coleção do Firestore.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string", "example": "João Silva" },
                  "idade": { "type": "integer", "example": 25 },
                  "telefone": { "type": "string", "example": "(88) 99999-9999" },
                  "email": { "type": "string", "example": "paciente@email.com" },
                  "objetivo": { "type": "string", "example": "Emagrecimento" },
                  "meta": { "type": "number", "example": 75 },
                  "pesoInicial": { "type": "number", "example": 85 },
                  "pesoAtual": { "type": "number", "example": 85 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Paciente adicionado com sucesso!"
          }
        }
      }
    },
    "/api/pacientes/{id}/historico": {
      "post": {
        "tags": ["Pacientes"],
        "summary": "Adiciona uma nova medição ao histórico de evolução",
        "description": "Insere um novo registro de medição ao final da lista de histórico do paciente e atualiza automaticamente seu peso atual.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do paciente no Firestore",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": { "type": "string", "example": "21/06/2026" },
                  "peso": { "type": "number", "example": 79.5 },
                  "cintura": { "type": "number", "example": 86.0 },
                  "quadril": { "type": "number", "example": 96.0 },
                  "variacao": { "type": "string", "example": "↓ 1.0 kg" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Medição adicionada ao histórico com sucesso!" },
          "400": { "description": "Erro na requisição" }
        }
      }
    },
    "/api/pacientes/{id}/plano": {
      "put": {
        "tags": ["Pacientes"],
        "summary": "Atualiza o plano alimentar de um paciente",
        "description": "Substitui o plano alimentar atual do paciente pelo novo objeto enviado no corpo da requisição.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do paciente no Firestore",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cafeManha": { "type": "string", "example": "2 ovos e café" },
                  "lancheManha": { "type": "string", "example": "1 maçã" },
                  "almoco": { "type": "string", "example": "Arroz, feijão e frango" },
                  "lancheTarde": { "type": "string", "example": "Iogurte" },
                  "jantar": { "type": "string", "example": "Salada e peixe" },
                  "ceia": { "type": "string", "example": "Chá de camomila" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Plano alimentar salvo com sucesso!" },
          "400": { "description": "Erro na requisição" }
        }
      }
    },
    "/api/pacientes/{id}": {
      "put": {
        "tags": ["Pacientes"],
        "summary": "Atualiza os dados gerais e a evolução de um paciente",
        "description": "Permite alterar qualquer informação do paciente, incluindo dados cadastrais, metas e o histórico completo de medições.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do paciente no Firestore",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string", "example": "João Silva" },
                  "idade": { "type": "integer", "example": 25 },
                  "telefone": { "type": "string", "example": "(88) 99999-9999" },
                  "email": { "type": "string", "example": "paciente@email.com" },
                  "objetivo": { "type": "string", "example": "Emagrecimento" },
                  "meta": { "type": "number", "example": 75 },
                  "pesoInicial": { "type": "number", "example": 85 },
                  "pesoAtual": { "type": "number", "example": 80.5 },
                  "historico": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "data": { "type": "string", "example": "10/05/2026" },
                        "peso": { "type": "number", "example": 80.5 },
                        "cintura": { "type": "number", "example": 87.5 },
                        "quadril": { "type": "number", "example": 97.5 },
                        "variacao": { "type": "string", "example": "↓ 0.5 kg" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Dados do paciente atualizados com sucesso!" },
          "400": { "description": "Erro na requisição" }
        }
      },
      "delete": {
        "tags": ["Pacientes"],
        "summary": "Exclui um paciente do sistema",
        "description": "Remove permanentemente o documento do paciente da coleção do Firestore baseado no ID fornecido.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do paciente no Firestore",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": { "description": "Paciente excluído com sucesso!" },
          "400": { "description": "Erro na requisição" }
        }
      }
    },
    "/api/receitas": {
      "get": {
        "tags": [
          "Receitas"
        ],
        "summary": "Lista receitas",
        "description": "Retorna um array com as receitas do Firebase.",
        "responses": {
          "200": {
            "description": "Lista retornada com sucesso."
          }
        }
      },
      "post": {
        "tags": [
          "Receitas"
        ],
        "summary": "Cria receita",
        "description": "Adiciona uma nova receita ao catálogo.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titulo": {
                    "type": "string",
                    "example": "Panqueca de Banana Proteica"
                  },
                  "descricao": {
                    "type": "string",
                    "example": "Lorem ipsum, dolor sit amet consectetur adipisicing elit. Officia quisquam doloremque nostrum laboriosam, blanditiis libero corporis nulla a aut?"
                  },
                  "tempoPreparo": {
                    "type": "string",
                    "example": "15 minutos"
                  },
                  "imagem": {
                    "type": "string",
                    "example": "https://images.unsplash.com/photo-exemplo"
                  },
                  "categoria": {
                    "type": "string",
                    "example": "Café da Manhã"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Receita adicionada com sucesso!"
          }
        }
      }
    },
    "/api/receitas/{id}": {
      "put": {
        "tags": [
          "Receitas"
        ],
        "summary": "Edita/Atualiza uma receita existente",
        "description": "Atualiza os campos de uma receita salva no Firestore passando o seu ID no caminho.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID único da receita gerado pelo Firebase",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titulo": {
                    "type": "string",
                    "example": "Panqueca de Aveia Atualizada"
                  },
                  "descricao": {
                    "type": "string",
                    "example": "Nova descrição editada..."
                  },
                  "tempoPreparo": {
                    "type": "string",
                    "example": "20 minutos"
                  },
                  "imagem": {
                    "type": "string",
                    "example": "https://images.unsplash.com/photo-exemplo"
                  },
                  "categoria": {
                    "type": "string",
                    "example": "Café da Manhã"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Receita atualizada com sucesso!"
          },
          "400": {
            "description": "Erro na requisição ou ID inválido"
          }
        }
      }
    },
    "/api/agendamentos": {
      "get": {
        "tags": [
          "Agendamentos"
        ],
        "summary": "Lista todos os agendamentos cadastrados",
        "description": "Retorna um array com todos os agendamentos vindos do Firestore.",
        "responses": {
          "200": {
            "description": "Lista de agendamentos retornada com sucesso."
          }
        }
      },
      "post": {
        "tags": [
          "Agendamentos"
        ],
        "summary": "Cria um novo agendamento",
        "description": "Envia os dados do agendamento para a coleção do Firestore.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pacienteId": {
                    "type": "string",
                    "example": "abc123"
                  },
                  "pacienteNome": {
                    "type": "string",
                    "example": "Ana Farias"
                  },
                  "data": {
                    "type": "string",
                    "example": "2026-06-17"
                  },
                  "hora": {
                    "type": "string",
                    "example": "07:00"
                  },
                  "tipoConsulta": {
                    "type": "string",
                    "example": "Retorno"
                  },
                  "status": {
                    "type": "string",
                    "example": "Confirmada"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Agendamento adicionado com sucesso!"
          }
        }
      }
    }
  }
}